{
  "name": "er-theme",
  "version": "1.0.0",
  "description": "Er theme with CSS",
  "main": "index.js",
  "scripts": {
    "dev:css": "npx @tailwindcss/cli -i ./assets/css/app.css -o ./assets/css/main.css --watch",
    "dev:server": "hugo server --disableFastRender",
    "build:css": "npx @tailwindcss/cli -i ./assets/css/app.css -o ./assets/css/main.css --minify",
    "build": "pnpm run build:css && hugo --minify"
  },
  "keywords": [
    "hugo",
    "theme"
  ],
  "author": "Darwin Wu",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.12",
    "@tailwindcss/typography": "^0.5.16",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.12"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
